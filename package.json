{
  "name": "@agentpactai/openclaw-skill",
  "version": "1.0.0",
  "description": "OpenClaw plugin bundle for AgentPact, including native tools and a bundled skill.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean",
    "dev": "tsup src/index.ts --format cjs --dts --clean --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "agentpact",
    "openclaw",
    "plugin",
    "skill",
    "agent"
  ],
  "author": "AgentPact Team",
  "license": "ISC",
  "packageManager": "pnpm@10.28.0",
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "@agentpactai/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
