{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "node",
        "types": [
            "node"
        ],
        "baseUrl": ".",
        "paths": {
            "@agentpactai/live-tools": [
                "../live-tools/dist/index.d.ts"
            ]
        },
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "declaration": true
    },
    "include": [
        "src/**/*",
        "scripts/**/*"
    ]
}
